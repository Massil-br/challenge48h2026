# =============================================================================
# ParkShare Analytics — Variables d'environnement
# =============================================================================
# Copier ce fichier en .env et adapter les valeurs selon votre configuration.

# -----------------------------------------------------------------------------
# Base de données PostgreSQL
# -----------------------------------------------------------------------------
# URL de connexion complète (utilisée par Prisma)
DATABASE_URL="postgresql://parkshare:votre_mot_de_passe@localhost:5432/parkshare?schema=public"

# Variables individuelles (utilisées par docker-compose)
POSTGRES_USER=parkshare
POSTGRES_PASSWORD=votre_mot_de_passe
POSTGRES_DB=parkshare
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Application Next.js
# -----------------------------------------------------------------------------
# Port d'écoute (défaut: 3000)
PORT=3000

# Mode (development | production)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Chemins des données (pour déploiement personnalisé)
# -----------------------------------------------------------------------------
# Chemin vers le CSV des KPIs (relatif au dossier app/)
DATA_CSV_PATH=../data/output/kpis_par_commune.csv

# =============================================================================
# Pour Docker Compose, seules ces variables sont nécessaires:
# POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB
# Le DATABASE_URL est construit automatiquement dans docker-compose.yml
# =============================================================================
